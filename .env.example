# 后端配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_assistant
STORAGE_PATH=./storage
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Embedding 配置
# local: 使用本地 hash embedding，无需 API Key，默认 384 维
# openai_compatible: 需要配置 EMBEDDING_API_KEY 和 EMBEDDING_BASE_URL
# 真实模型示例：EMBEDDING_PROVIDER=openai_compatible, EMBEDDING_MODEL=BAAI/bge-m3, EMBEDDING_DIMENSION=1024
# MiMo Token Plan 不提供 embedding endpoint，推荐使用 Silicon Flow bge-m3
# 切换真实 embedding 后必须 rebuild embeddings，维度变化需重建 DB volume
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash
EMBEDDING_DIMENSION=384
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_TIMEOUT_SECONDS=60

# LLM 配置
# local: 使用本地占位 LLM，无需 API Key
# openai_compatible: 需要配置 LLM_API_KEY 和 LLM_BASE_URL
# 真实模型示例：LLM_PROVIDER=openai_compatible, LLM_MODEL=mimo-v2.5-pro
# 真实模型可能产生费用，不要提交 .env
LLM_PROVIDER=local
LLM_MODEL=local-mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60

# 真实模型强制模式
# true: LLM_PROVIDER 必须是 openai_compatible，且 API Key / Base URL / Model 必须存在
# false: 允许 local provider 运行
REAL_MODEL_REQUIRED=false

# RAG 配置
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.1
RAG_EVIDENCE_THRESHOLD=0.2

# Provider 稳定性配置
# PROVIDER_TIMEOUT_SECONDS=60  # 预留统一超时上限，当前未生效；LLM/Embedding 各自使用专用 timeout
# PROVIDER_MAX_RETRIES=2
# PROVIDER_RETRY_BACKOFF_SECONDS=1.0

# 生产配置
# ENV: 运行环境标识
#   production: 启用生产模式检查（CORS/cookie/auth 更严格）
#   development: 开发模式（宽松检查）
ENV=development

# CORS_ALLOWED_ORIGINS: 允许的跨域来源，逗号分隔
#   生产推荐：https://your-domain.com（仅 HTTPS 域名，不含 localhost/127.0.0.1）
#   本地 HTTP 开发：http://localhost:3000,http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# AUTH_ENABLED: 是否启用真实认证（注册/登录/session）
#   生产推荐：true
#   本地开发：false（使用 X-User-Id header 模拟用户）
AUTH_ENABLED=false

# ALLOW_DEV_USER_HEADER: 是否允许 X-User-Id 请求头模拟用户
#   生产推荐：false（防止身份伪造）
#   本地开发：true（方便测试多用户隔离）
ALLOW_DEV_USER_HEADER=true

# SESSION_COOKIE_SECURE: Session Cookie 是否设置 Secure 属性
#   生产推荐：true（需要 HTTPS，否则浏览器不会发送 Cookie）
#   本地 HTTP 开发：false（HTTP 下 Secure Cookie 不会被浏览器发送）
SESSION_COOKIE_SECURE=false

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
